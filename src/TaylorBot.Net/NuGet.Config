<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Discord.Net" />
    </packageSource>
    <!-- Directory.Build.props injects this optional source when UseTaylorBotFeed is true. -->
    <packageSource key="https://pkgs.dev.azure.com/adamgauthier/TaylorBot/_packaging/taylorbot-feed/nuget/v3/index.json">
      <package pattern="Discord.Net" />
    </packageSource>
  </packageSourceMapping>
</configuration>
